---
layout: null
permalink: /search.json
---
[
{% for post in site.posts %}
  {% assign search_type = '노트' %}
  {% if post.categories contains 'papers' %}{% assign search_type = '논문' %}{% elsif post.categories contains 'subprojects' or post.categories contains 'projects' %}{% assign search_type = '프로젝트' %}{% elsif post.categories contains 'tistory' %}{% assign search_type = '이전 기록' %}{% endif %}
  {
    "title": {{ post.title | jsonify }},
    "summary": {{ post.summary | default: post.excerpt | strip_html | strip_newlines | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: '%Y.%m.%d' | jsonify }},
    "timestamp": {{ post.date | date: '%s' }},
    "type": {{ search_type | jsonify }},
    "venue": {{ post.venue | default: '' | jsonify }},
    "tags": {{ post.tags | default: empty | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
